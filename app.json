{
  "expo": {
    "name": "Spendoraa",
    "slug": "Spendora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app_icons/GooglePlayStore.png",
    "scheme": "spendora",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/app_icons/GooglePlayStore.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.techiee349.Spendora",
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/app_icons/GooglePlayStore.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app_icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#63B7B1",
          "dark": {
            "backgroundColor": "#63B7B1"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Spendoraa accesses your photos so you can choose a profile picture.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5422e4df-02b2-4a7a-8380-6a1d1dbfa75b"
      }
    }
  }
}
